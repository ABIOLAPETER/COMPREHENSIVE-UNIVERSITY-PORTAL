## 4. Making API Requests

Create a single `api.js` file that all your components use. Never write `fetch` calls directly in components.

```javascript
// src/api/api.js
import axios from "axios";

const API_BASE = "https://comprehensive-university-portal-production-6f10.up.railway.app/v1/api";

let accessToken = localStorage.getItem("token") || null;

const api = axios.create({
  baseURL: API_BASE,
  withCredentials: true, // REQUIRED — this sends the httpOnly cookie on every request
});

// Attach token to every request
api.interceptors.request.use((config) => {
  if (accessToken) {
    config.headers.Authorization = `Bearer ${accessToken}`;
  }
  return config;
});

// Handle 401 — auto refresh token
api.interceptors.response.use(
  (response) => response,
  async (error) => {
    const originalRequest = error.config;

    if (error.response?.status === 401 && !originalRequest._retry) {
      originalRequest._retry = true;

      try {
        const res = await axios.post(`${API_BASE}/auth/refresh`, {}, { withCredentials: true });
        accessToken = res.data.data.accessToken;
        localStorage.setItem("token", accessToken);
        originalRequest.headers.Authorization = `Bearer ${accessToken}`;
        return api(originalRequest);
      } catch (refreshError) {
        localStorage.clear();
        window.location.href = "/login";
        return Promise.reject(refreshError);
      }
    }

    return Promise.reject(error);
  }
);

export default api;
```

### Using it in a component:
```javascript
import api from "../api/api";

// GET request
const response = await api.get("/faculties");
const faculties = response.data.data; // always .data.data

// POST request
const response = await api.post("/auth/login", { email, password });

// PATCH request
const response = await api.patch(`/registrations/${id}/approve`);

// DELETE request
const response = await api.delete(`/registrations/${regId}/courses/${courseId}`);
```

